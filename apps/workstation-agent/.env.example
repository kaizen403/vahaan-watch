CENTRAL_API_URL=http://localhost:3003
DEVICE_PROVISIONING_TOKEN=
DEVICE_ID=ws-001
DEVICE_NAME=Workstation Alpha
CAMERA_SOURCE=rtsp://192.168.1.100:554/stream
CAMERA_FPS=2
OCR_PROVIDER=carmen
OCR_LANG=eng
OCR_MIN_CONFIDENCE=0.55
OCR_WORKER_COUNT=2
DB_PATH=./data/workstation.db
SNAPSHOT_DIR=./data/snapshots
SNAPSHOT_RETENTION_DAYS=30
SNAPSHOT_MAX_WIDTH=1280
SNAPSHOT_JPEG_QUALITY=80
HITLIST_SYNC_INTERVAL_MS=60000
HEARTBEAT_INTERVAL_MS=30000
OUTBOX_FLUSH_INTERVAL_MS=15000
OUTBOX_BATCH_SIZE=20
TABLET_WS_PORT=8089
TTS_ENABLED=true
LOG_LEVEL=info

# Carmen Video SDK (used when OCR_PROVIDER=carmen)
CARMEN_BINARY_PATH=../../sdk_samples/samples/C++/build/05_cloud/cpp_sample_05_cloud
CARMEN_API_KEY=
CARMEN_REGION=IND

# RTSP Configuration for CC Camera Monitoring
RTSP_TRANSPORT=tcp
RTSP_CONNECT_TIMEOUT_MS=10000
RTSP_READ_TIMEOUT_MS=20000
RTSP_RECONNECT_MAX_ATTEMPTS=5
RTSP_STREAM_VALIDATION_INTERVAL_MS=30000

# Multiple Camera Sources (JSON array format)
# Example: CAMERA_SOURCES_JSON='[{"url":"rtsp://192.168.1.100:554/stream","label":"Main Gate","fps":2},{"url":"rtsp://192.168.1.101:554/stream","label":"Parking Lot","fps":1}]'
CAMERA_SOURCES_JSON=
