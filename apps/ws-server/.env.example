# Preferred env name for the realtime Vehicle API.
VEHICLE_API_KEY=<vehicle-api-key>

# Legacy fallback still supported by the WS server for older deployments:
# CARMEN_API_KEY=<vehicle-api-key>

WS_PORT=3002
VEHICLE_API_BASE=https://ap-southeast-1.api.carmencloud.com/vehicle
DB_RETRY_MS=5000

# PostgreSQL
POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5434/carmen_anpr
DB_SCHEMA=public
BLACKLIST_COLLECTION=blacklisted_plates
DETECTIONS_COLLECTION=detections
SEED_DUMMY_BLACKLIST=false
WS_ADMIN_TOKEN=<set-this-to-enable-privileged-ws-commands>

# Plate encryption key (change this in production)
PLATE_ENCRYPTION_KEY=change_this_to_a_long_secret_key
