{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/startup/layout,_N_T_/(app)/startup/page,_N_T_/startup"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/startup/__PAGE__",
    "/!KGFwcCk/startup",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}